{
  "name": "blog183",
  "private": true,
  "scripts": {
    "dev": "hugo serve --minify --gc --port=8080 --bind=0.0.0.0 --baseURL=http://127.0.0.1:8080",
    "dev:host": "hugo serve --minify --gc --port=8080 --bind=0.0.0.0 --baseURL=http://$(hostname -I | awk '{print $1}'):8080",
    "pagefind": "npx pagefind --site public --output-subdir ../pagefind",
    "build": "hugo --cleanDestinationDir && npm run pagefind"
  },
  "devDependencies": {
    "pagefind": "^1.1.0"
  }
}
